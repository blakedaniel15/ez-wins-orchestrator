# ── Database (Neon) ───────────────────────────────────────────────────
# Provisioned via Vercel → Storage → Neon; injected automatically on Vercel.
DATABASE_URL=

# ── Auth / sessions ───────────────────────────────────────────────────
# Single-user internal tool. Login mints a Redis-backed session token; the
# cookie holds the token, never the password.
ADMIN_PASSWORD=

# ── Redis (Upstash) ───────────────────────────────────────────────────
# Vercel KV / Upstash. Either KV_* or UPSTASH_* names work.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── ClickUp ───────────────────────────────────────────────────────────
# Raw token is the Authorization header value (NOT "Bearer ...").
CLICKUP_API_TOKEN=
# UUID of the `project_id` text custom field. If the four lists use different
# field UUIDs, set the per-list overrides too.
CLICKUP_PROJECT_ID_FIELD_UUID=
# UUID of the `dealer_id` text custom field (the universal Dealer ID stamped on
# every task so it rolls up to its dealership).
CLICKUP_DEALER_ID_FIELD_UUID=
# The four ClickUp lists (coarse stage buckets).
CLICKUP_LIST_FEED_APPROVAL=901113435718
CLICKUP_LIST_ONBOARDING_WORKING=901105435045
CLICKUP_LIST_SUPPORT=901106848667
CLICKUP_LIST_PLANNER=901111643961

# ── Microsoft Graph (Outlook) ─────────────────────────────────────────
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_USER_EMAIL=

# ── Portal ────────────────────────────────────────────────────────────
# Base URL of the ez-wins-portal deployment (its /api/storage is called).
PORTAL_BASE_URL=
